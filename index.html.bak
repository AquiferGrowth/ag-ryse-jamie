<body class="body body_bg">
  <section class="section navbar">
    <div class="container-large nav-container">
      <a href="index.html" class="navbar-logo-text">Jamie<span class="navbar-logo-dot">.</span></a>
      <nav class="nav-menu">
        <a href="index.html" class="nav-link w--current">Home</a>
        <a href="#" class="nav-link">About</a>
        <a href="blogs.html" class="nav-link">Blog</a>
      </nav>
    </div>
  </section>
  <section class="hero-heading-left">
    <div class="container-large">
      <div class="hero-wrapper">
        <div class="hero-content">
          <div class="tech-tag">
            <div class="tech-tag-dot"></div>
            <div class="tech-tag-text">Tech Reviewer • NYC</div>
          </div>
          <h1 class="hero_heading">Hey,<br>I’m Jamie.</h1>
          <p class="page_text">I test tech products in my NYC apartment and share what actually works. No sponsored fluff, just honest reviews from someone who values quality over hype.</p>
          <div class="w-layout-hflex new_hflex">
            <a href="#" class="button-primary w-button">Read My Reviews</a>
            <a href="#" class="button-secondry w-button">About Me</a>
          </div>
        </div>
        <div class="hero-image-wrapper">
          <div class="jamie-portrait-container">
            <div class="jamie-portrait-glow"></div>
            <img src="images/jamie-portrait.png" loading="lazy" alt="Jamie Portrait" class="jamie-portrait-img">
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="hero-why" style="background: #0F1E2E !important;">
    <div class="container-large" style="padding: 120px 0;">
      <div class="about-wrapper">
        <div class="about-content">
          <div class="browse-topics-label">
            <div class="browse-topics-line"></div>
            <div class="browse-topics-text">ABOUT</div>
          </div>
          <h2 class="what-i-cover-heading">Why I Started This Blog</h2>
          <p class="page_text-copy" style="font-size: 21px; line-height: 1.8; color: #B4C5D6; margin-bottom: 28px;">I got tired of buying tech that looked great in marketing videos but fell flat in real life. So I started testing products myself, documenting what actually worked, and sharing honest takes with people who value authenticity over hype.</p>
          <p class="page_text-copy" style="font-size: 21px; line-height: 1.8; color: #B4C5D6; margin-bottom: 28px;">Living in a 650 sq ft NYC apartment means every purchase needs to earn its place. No room for gadgets that don't deliver. That constraint became my superpower—I only recommend what survives real-world use.</p>
          <p class="page_text-copy" style="font-size: 21px; line-height: 1.8; color: #B4C5D6;">This blog is for people who want real insights, not affiliate-driven recommendations. If you're optimizing your space or upgrading your routine, you're in the right place.</p>
        </div>
        <div class="topics-content">
          <div class="browse-topics-label">
            <div class="browse-topics-line"></div>
            <div class="browse-topics-text">BROWSE TOPICS</div>
          </div>
          <h2 class="what-i-cover-heading">What I Cover</h2>
          <div class="topics-list">
            <!-- Topic Card 1 -->
            <a href="#" class="topic-card">
              <div class="topic-icon-bg"><img src="images/topic-smart-home.svg" loading="lazy" alt="Smart Home"></div>
              <div>
                <div class="topic-title">Smart Home</div>
                <div class="topic-posts">24 posts</div>
              </div>
            </a>
            <!-- Topic Card 2 -->
            <a href="#" class="topic-card">
              <div class="topic-icon-bg"><img src="images/topic-productivity.svg" loading="lazy" alt="Productivity"></div>
              <div>
                <div class="topic-title">Productivity</div>
                <div class="topic-posts">18 posts</div>
              </div>
            </a>
            <!-- Topic Card 3 -->
            <a href="#" class="topic-card">
              <div class="topic-icon-bg"><img src="images/topic-tech-reviews.svg" loading="lazy" alt="Tech Reviews"></div>
              <div>
                <div class="topic-title">Tech Reviews</div>
                <div class="topic-posts">31 posts</div>
              </div>
            </a>
            <!-- Topic Card 4 -->
            <a href="#" class="topic-card">
              <div class="topic-icon-bg"><img src="images/topic-urban-living.svg" loading="lazy" alt="Urban Living"></div>
              <div>
                <div class="topic-title">Urban Living</div>
                <div class="topic-posts">12 posts</div>
              </div>
            </a>
            <!-- Topic Card 5 -->
            <a href="#" class="topic-card">
              <div class="topic-icon-bg"><img src="images/topic-condo-life.svg" loading="lazy" alt="Condo Life"></div>
              <div>
                <div class="topic-title">Condo Life</div>
                <div class="topic-posts">15 posts</div>
              </div>
            </a>
            <!-- Topic Card 6 -->
            <a href="#" class="topic-card">
              <div class="topic-icon-bg"><img src="images/topic-honest-takes.svg" loading="lazy" alt="Honest Takes"></div>
              <div>
                <div class="topic-title">Honest Takes</div>
                <div class="topic-posts">28 posts</div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="hero-without-image">
    <div class="container-large" style="padding: 120px 0;">
      <div class="hero-wrapper-two">
        <div class="w-layout-hflex title_flex" style="align-items: center; gap: 12px; margin-bottom: 24px;">
          <div style="width: 40px; height: 2px; background: #12F7D6;"></div>
          <p class="new_text" style="color: #12F7D6; font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase;">Featured Work</p>
        </div>
        <div class="featured-header">
          <h2 class="page_heading-copy" style="font-family: 'Rufina', serif; font-size: 72px; color: #FFFFFF; line-height: 1.1; margin: 0; letter-spacing: -0.72px;">Latest Reviews & Insights</h2>
          <a href="#" class="button-primary w-button">View All</a>
        </div>
        
        <div class="blog-grid">
          <!-- Blog Card 1 -->
          <div class="blog-card">
            <div class="blog-card-img-wrapper">
              <img src="images/smart-home-blog.png" alt="Smart Home" class="blog-card-img">
              <div class="blog-card-overlay"></div>
              <div class="blog-card-tag">Smart Home</div>
            </div>
            <div class="blog-card-content">
              <h3 class="blog-card-title">Building a Smart Home That Actually Works</h3>
              <p class="blog-card-excerpt">After two years of trial and error, here's what I learned about creating a smart home setup that doesn't make you want to throw everything out the window.</p>
              <div class="blog-card-footer">
                <div class="blog-card-meta">
                  Jan 28, 2026 <div class="meta-dot"></div> 8 min
                </div>
                <div class="arrow-circle">→</div>
              </div>
            </div>
          </div>
          
          <!-- Blog Card 2 -->
