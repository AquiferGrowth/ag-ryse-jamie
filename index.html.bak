}

/* Responsive Utilities */
.container-large {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    padding-left: 24px;
    padding-right: 24px;
    box-sizing: border-box;
}

.nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
}

.nav-menu {
    display: flex;
    align-items: center;
}

.hero-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 48px;
}

.hero-content {
    flex: 1;
    max-width: 600px;
}

.hero-image-wrapper {
    flex: 1;
    display: flex;
    justify-content: flex-end;
}

.about-wrapper {
    display: flex;
    gap: 80px;
    align-items: flex-start;
}

.about-content {
    flex: 1.2;
}

.topics-content {
    flex: 1;
}

.topics-list {
    display: flex;
    flex-direction: column;
    gap: 0;
}

.blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    width: 100%;
}

.featured-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
    margin-bottom: 60px;
}

.footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 64px;
}

.footer-links {
    display: flex;
    gap: 40px;
}

.footer-socials {
    display: flex;
    gap: 32px;
}

/* Media Queries */
@media screen and (max-width: 1100px) {
    .hero_heading {
        font-size: 80px !important;
    }
    .what-i-cover-heading {
        font-size: 64px;
    }
    .jamie-portrait-container {
        width: 400px;
        height: 400px;
    }
}

@media screen and (max-width: 991px) {
    .navbar {
        padding: 20px 24px !important;
    }
    .hero-heading-left {
        padding: 80px 0;
    }
    .hero-wrapper {
        flex-direction: column;
        text-align: center;
        gap: 60px;
    }
    .hero-content {
        max-width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .hero-image-wrapper {
        justify-content: center;
    }
    .page_text {
        margin-left: auto;
        margin-right: auto;
    }
    .about-wrapper {
        flex-direction: column;
        gap: 60px;
    }
    .blog-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    .featured-header {
        flex-direction: column;
        align-items: flex-start !important;
        gap: 20px;
    }
}

@media screen and (max-width: 767px) {
    .container-large {
        padding-left: 20px;
        padding-right: 20px;
    }
    .nav-container {
        flex-direction: column;
        gap: 20px;
        padding: 10px 0;
    }
    .nav-menu {
        justify-content: center;
        width: 100%;
    }
    .nav-link {
        margin: 0 15px !important;
    }
    .hero_heading {
        font-size: 60px !important;
        line-height: 1.1 !important;
    }
    .page_text {
        font-size: 20px !important;
    }
    .what-i-cover-heading {
        font-size: 48px;
    }
    .jamie-portrait-container {
        width: 320px;
        height: 320px;
    }
    .blog-grid {
        grid-template-columns: 1fr;
    }
    .footer-dark-copy {
        padding: 60px 24px 40px !important;
    }
    .footer-top {
        flex-direction: column;
        gap: 40px;
        align-items: center !important;
        text-align: center;
    }
    .footer-links, .footer-socials {
        justify-content: center;
    }
    .navbar-logo-text {
        font-size: 32px;
    }
}

@media screen and (max-width: 479px) {
    .hero_heading {
        font-size: 48px !important;
    }
    .new_hflex {
        flex-direction: column;
        width: 100%;
        gap: 12px;
    }
    .button-primary, .button-secondry {
        width: 100%;
        text-align: center;
    }
    .jamie-portrait-container {
        width: 260px;
        height: 260px;
    }
    .footer-links, .footer-socials {
        flex-direction: column;
        gap: 16px;
    }
}
</style>
